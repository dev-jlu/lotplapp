@inherits LayoutComponentBase

<!-- Fixed topbar -->
<header class="fixed top-0 left-0 right-0 h-14 bg-primary shadow-md z-50 flex items-center px-6 justify-between">
    <a href="/" class="text-white font-bold text-lg tracking-wide">Lotplapp</a>

    <nav class="flex items-center gap-6">
        <AuthorizeView Roles="Admin,Owner,Seller,Reporter">
            <Authorized>
                <a href="/users" class="text-white/80 hover:text-white text-sm font-medium transition">Users</a>
            </Authorized>
        </AuthorizeView>

        <form method="post" action="/auth/logout" class="inline">
            <AntiforgeryToken />
            <button type="submit"
                    class="text-sm font-medium text-white/80 hover:text-white transition">
                Logout
            </button>
        </form>
    </nav>
</header>

<!-- Page content offset for fixed topbar -->
<main class="pt-14 min-h-screen bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        @Body
    </div>
</main>

<!-- Blazor error UI (id preserved for Blazor runtime) -->
<div id="blazor-error-ui" data-nosnippet
     class="hidden fixed bottom-4 left-1/2 -translate-x-1/2 bg-red-600 text-white px-4 py-3 rounded-lg shadow-lg text-sm">
    An unhandled error has occurred.
    <a href="." class="underline ml-2">Reload</a>
    <span class="dismiss ml-2 cursor-pointer">✕</span>
</div>

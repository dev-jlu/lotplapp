@layout MainLayout
@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="bg-white rounded-xl shadow-md p-6 max-w-md mx-auto mt-16 text-center">
    <div class="text-5xl text-red-400 mb-4">&#9888;</div>
    <h1 class="text-xl font-semibold text-gray-800 mb-2">Error.</h1>
    <h2 class="text-xl font-semibold text-gray-800 mb-2">An error occurred while processing your request.</h2>

    @if (ShowRequestId)
    {
        <p class="mb-4">
            <strong>Request ID:</strong>
            <code class="text-xs text-gray-400 bg-gray-100 px-2 py-1 rounded">@RequestId</code>
        </p>
    }

    <a href="/"
       class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-primary text-white text-sm font-medium hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition mt-6">
        Return to Home
    </a>
</div>

<environment include="Development">
    <p class="text-xs text-gray-400 max-w-md mx-auto mt-4 text-center">
        <strong>Development Mode:</strong>
        Swapping to the <strong>Development</strong> environment will display more detailed information about the error that occurred.
        The Development environment shouldn't be enabled for deployed applications.
        Enable it by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong> and restarting the app.
    </p>
</environment>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

@page "/users"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "Admin,Owner,Reporter")]

<h2>User Management</h2>

<AuthorizeView Roles="Admin,Owner">
    <Authorized>
        <a href="/users/create">+ Create User</a>
    </Authorized>
</AuthorizeView>

<div>
    <input @bind="_nameFilter" @bind:event="oninput" placeholder="Search by name or email..." />

    <select @bind="_roleFilter">
        <option value="">All Roles</option>
        <option value="Admin">Admin</option>
        <option value="Owner">Owner</option>
        <option value="Seller">Seller</option>
        <option value="Reporter">Reporter</option>
    </select>

    <select @bind="_statusFilter">
        <option value="">All Statuses</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
    </select>
</div>

@if (_users is null)
{
    <p>Loading...</p>
}
else if (!FilteredUsers.Any())
{
    <p>No users found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in FilteredUsers)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(_roles.GetValueOrDefault(user.Id, "—"))</td>
                    <td>@(user.IsActive ? "Active" : "Inactive")</td>
                    <td>@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                    <td>
                        <AuthorizeView Roles="Admin,Owner">
                            <Authorized>
                                <a href="/users/edit/@user.Id">Edit</a>
                                @if (user.IsActive)
                                {
                                    <button @onclick="() => HandleSetActiveAsync(user.Id, false)">Deactivate</button>
                                }
                                else
                                {
                                    <button @onclick="() => HandleSetActiveAsync(user.Id, true)">Reactivate</button>
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
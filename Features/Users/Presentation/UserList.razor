@page "/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "Admin,Owner,Reporter")]

<h2>User Management</h2>

<AuthorizeView Roles="Admin,Owner">
    <Authorized>
        <a href="/users/create">+ Create User</a>
    </Authorized>
</AuthorizeView>

@if (_users is null)
{
    <p>Loading...</p>
}
else if (!_users.Any())
{
    <p>No users found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(_roles.GetValueOrDefault(user.Id, "—"))</td>
                    <td>@(user.IsActive ? "Active" : "Inactive")</td>
                    <td>@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
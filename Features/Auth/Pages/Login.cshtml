@page "/auth/login"
@model Lotplapp.Features.Auth.Pages.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="bg-white rounded-xl shadow-md p-6">
    <h2 class="text-xl font-semibold text-primary mb-6 text-center">Sign in to your account</h2>

    <div asp-validation-summary="ModelOnly"
         class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-700"></div>

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input asp-for="Input.Email" type="email" autocomplete="email"
                   class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" />
            <span asp-validation-for="Input.Email" class="text-xs text-red-600 mt-1"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password"
                   class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" />
            <span asp-validation-for="Input.Password" class="text-xs text-red-600 mt-1"></span>
        </div>

        <div class="mb-6 flex items-center gap-2 text-sm text-gray-600">
            <input asp-for="Input.RememberMe" type="checkbox" class="rounded border-gray-300" />
            <label asp-for="Input.RememberMe">Remember me</label>
        </div>

        <button type="submit"
                class="inline-flex items-center justify-center w-full px-4 py-2 rounded-md bg-primary text-white text-sm font-medium hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition disabled:opacity-50 disabled:cursor-not-allowed">
            Sign in
        </button>
    </form>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Lotplapp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary:   { DEFAULT: '#1E3A5F', light: '#2D5186', dark: '#132740' },
              accent:    { DEFAULT: '#C9A84C', light: '#D9BC72', dark: '#A8872E' },
              surface:   { DEFAULT: '#F5F7FA', muted: '#E8EDF4' }
            }
          }
        }
      }
    </script>
</head>
<body class="min-h-screen bg-surface flex items-center justify-center">
    <div class="w-full max-w-md">
        <h1 class="text-primary font-bold text-3xl text-center mb-8">Lotplapp</h1>
        @RenderBody()
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@page "/auth/access-denied"
@model Lotplapp.Features.Auth.Pages.AccessDeniedModel

<div class="bg-white rounded-xl shadow-md p-6 text-center">
    <div class="text-5xl mb-4">🚫</div>
    <h2 class="text-xl font-semibold text-gray-800 mb-2">Access Denied</h2>
    <p class="text-gray-500 text-sm mb-6">You do not have permission to view this page.</p>
    <a href="/"
       class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-primary text-white text-sm font-medium hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition">
        Return to Home
    </a>
</div>
